  "publicApiSurface": [
    "TVBlock - Multi-block television display",
    "TVBlockEntity - Television block entity with cassette playback",
    "ViewFinderBlock - Camera viewfinder block",
    "ViewFinderBlockEntity - Viewfinder block entity with rotation",
    "CassetteItem - Cassette tape item",
    "HollowCassetteItem - Linkable cassette for live feeds",
    "CassetteTape - Data-driven tape definition registry",
    "BroadcastManager - System for managing live feed connections",
    "BroadcastLocationType - Registry for broadcast location types",
    "IBroadcastSource - Interface for broadcast sources",
    "ITvCassette - Interface for TV cassette implementations",
    "VistaLevelRenderer - Custom level rendering for cameras",
    "AdaptiveUpdateScheduler - Performance optimization for camera updates",
    "MsaaTarget - Multi-sample anti-aliasing render target"
